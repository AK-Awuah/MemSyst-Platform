# ─── Application ───────────────────────────────────────────────
APP_ENV=development
APP_PORT=3001
API_PREFIX=api/v1

# ─── Platform Domain ───────────────────────────────────────────
PLATFORM_DOMAIN=admin.memsyst.com
PLATFORM_DOMAIN_LOCAL=admin.localhost:3001

# ─── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=memsyst
DB_USER=memsyst_user
DB_PASSWORD=memsyst_secret
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=memsyst_redis_secret

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_64_CHARS_MINIMUM_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_REFRESH_SECRET_64_CHARS_MINIMUM
JWT_REFRESH_EXPIRES_IN=7d

# ─── Paystack ──────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_BASE_URL=https://api.paystack.co

# ─── Twilio (SMS) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Mailtrap (Email Dev) ──────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
SMTP_FROM=noreply@memsyst.com

# ─── Cloudflare R2 ─────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=memsyst-uploads
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ─── OTP ───────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ─── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5
